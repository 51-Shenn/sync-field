{
  "output": {
    "filePath": "repomix-output-all.xml",
    "style": "xml",
    "parsableStyle": true,
    "headerText": "SyncField — Field Operations DAG Engine + Next.js Frontend",
    "instructionFilePath": "AGENTS.md",
    "removeComments": false,
    "removeEmptyLines": false,
    "topFilesLength": 15,
    "showLineNumbers": true
  },
  "include": [
    "backend/**/*.py",
    "backend/**/*.sql",
    "backend/**/*.json",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css",
    "prisma/**/*.prisma",
    "prisma.config.ts",
    "next.config.ts",
    "proxy.ts",
    "tsconfig.json",
    "package.json",
    "AGENTS.md",
    "STRATEGY.md"
  ],
  "ignore": {
    "useGitignore": true,
    "customPatterns": [
      "repomix-output*.xml",
      "repomix-output*.xml",
      "package-lock.json",
      ".venv/",
      "__pycache__/",
      "*.pyc",
      "*.session*",
      "downloads/",
      "node_modules/",
      ".next/",
      "src/generated/prisma/",
      ".claude/"
    ]
  }
}
