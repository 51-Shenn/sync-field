# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# python / telethon
__pycache__/
.venv/
venv/
*.pyc
*.pyo
*.session
*.session-journal
downloads/

# repomix
repomix-output.*
repomix-changes.*

# Google Drive auth token (generated by setup_drive_auth.py)
drive_token.json

# logs
*.log
backend/bot_*.txt

# test scripts
backend/send_test*
test_send.*

# GCP service account keys
ai-study-assistant-*.json

# binary documents
*.docx
